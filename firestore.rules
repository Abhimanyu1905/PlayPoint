rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Public read: anyone can view user profiles (needed for landing page leaderboard + stats)
      allow read: if true;

      // Only the owner can write their own document
      allow write: if isSignedIn() && request.auth.uid == userId;

      // Admin has full control
      allow read, write, delete: if isAdmin();
    }

    match /game_history/{historyId} {
      // Authenticated users can log their own gameplay scores
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Owner can read their own history
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Public read for aggregate stats (count only — no sensitive data in game_history)
      allow read: if true;

      // Admin can read/write all
      allow read, write: if isAdmin();
    }
  }
}
